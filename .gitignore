# This file is based on the VisualStudio template from GitHub's gitignore repository.
# It helps to exclude files generated by Visual Studio and .NET development.

## Ignore Visual Studio Files ##
# User-Specific Files
*.user
*.suo
*.sln.docstates
*.vshost.exe
*.vshost.exe.config
*.log
*.vspscc
*.vssscc
*.builds
*.pyc

# Project and Solution Files
ipch/
*.aps
*.ncb
*.obj
*.pdb
*.opensdf
*.sdf
*.tlog
*.idb
_UpgradeReport_Files/
.vs/

## Ignore Binaries and Build Output ##
[Dd]ebug/
[Rr]elease/
[Xx]64/
[Ww]in32/
build/
bin/
obj/
*.exe
*.so
*.o
*.a
*.ilk
*.meta
*.exp

# Deployment and Publish
[Pp]ublish/
[Aa]pp_Data/

# Test results
*.trx

## Ignore other common items ##
# Environment and Configuration
.DS_Store # macOS files
Thumbs.db # Windows thumbnail cache
/packages
*~
imgui.ini
/.github/upgrades/*
*.tiled-session
